{
  "description": "Project-aware Sodium warm starts and durable checkpoints without transcript capture.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/sodium-lifecycle.mjs\"",
            "timeout": 10,
            "statusMessage": "Orienting with Sodium"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/sodium-lifecycle.mjs\"",
            "timeout": 10,
            "statusMessage": "Checking durable context"
          }
        ]
      }
    ]
  }
}
